# OS
[Dd]esktop.ini
Thumbs.db
.DS_Store

# IDE
.idea/
.vs/
*.suo
*.user

# Local development .csproj / .sln / .slnx (Unity auto-generates these at root)
*.csproj
*.sln
*.slnx
unity/Runtime/Core/*.csproj
unity/Runtime/Mqtt/*.csproj
unity/Runtime/Core/*.csproj.meta
unity/Runtime/Mqtt/*.csproj.meta
unity/Runtime/Core/*.asmdef.meta
unity/Runtime/Mqtt/*.asmdef.meta
# ただし、手動で作成した src/ と tests/ 以下のプロジェクトファイルは Git 管理に含める
!src/**/*.csproj
!tests/**/*.csproj
!src/**/*.slnx
omnisharp.json

# .NET build output (redirected here from src/ to avoid Unity DLL conflicts)
artifacts/
src/**/*.meta

# Unity & .NET standard build outputs
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]in/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
*.pidb.meta
*.pdb.meta

# Unity DLL dependencies (install manually or via NuGet for Unity)
unity/Runtime/Core/Plugins/*.dll
unity/Runtime/Core/Plugins/*.dll.meta
unity/Runtime/Mqtt/Plugins/*.dll
unity/Runtime/Mqtt/Plugins/*.dll.meta
